# ============================================================
# StockInvestmentDSS — System environment template
# Runnable DSS application / local PoC
# ============================================================

APP_ENV=local
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend / local app
FRONTEND_PORT=3000
FRONTEND_API_BASE_URL=http://localhost:8000

# Local runtime data
RUNTIME_DATA_PATH=./runtime-data
DUCKDB_PATH=./runtime-data/market_research.duckdb

# Demo authentication
DEMO_LOGIN_ENABLED=true
DEMO_USERNAME=demo
DEMO_PASSWORD=demo

# Data source toggles
YFINANCE_ENABLED=true

# Feature flags
ENABLE_AUDIT_LOG=true
ENABLE_RISK_OUTPUT=true