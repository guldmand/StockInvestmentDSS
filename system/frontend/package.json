{
  "name": "stockinvestmentdss-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend for the StockInvestmentDSS PoC.",
  "scripts": {
    "build:css": "sass --load-path=node_modules --quiet-deps --silence-deprecation=import,global-builtin,color-functions,if-function --no-source-map src/scss:app/static/css",
    "watch:css": "sass --watch --load-path=node_modules --quiet-deps --silence-deprecation=import,global-builtin,color-functions,if-function --no-source-map src/scss:app/static/css"
  },
  "devDependencies": {
    "sass": "^1.99.0"
  },
  "dependencies": {
    "bootstrap": "^5.3.8"
  }
}