    "learning_rate": 0.0001,
    "gamma": 0.99,
    "kappa": 1.0,
    "grad_clip_norm": 10.0,
    "batch_size": 64,
    "replay_capacity": 100000,
    "num_tau_samples": 32,
    "num_tau_prime_samples": 32,
    "num_action_quantiles": 32,
    "epsilon_start": 1.0,
    "epsilon_final": 0.05,
    "epsilon_eval": 0.0,
    "epsilon_decay_steps": 15000,
    "target_update_interval": 1000,
    "use_layer_norm": true,
    "score_mode": "q50",
    "risk_lambda": null,
    "backtest_num_quantiles": 128,
    "eval_quantiles": 128,
    "backtest_max_steps": 10000
