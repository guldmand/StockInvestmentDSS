{
  "experiment_id": "clean_25k_baseline_v1",
  "schema_version": "1.0",
  "description": "Clean 10-ticker IQN 25k baseline with correct stockdss_long_v1 hyperparameters. No .env contamination. This is the authoritative baseline after config-contamination discovery (May 2026). All experiment-defining values are explicit here; .env must NOT override any of these.",

  "dataset": {
    "dataset_id": "demo_10_new_long_2010_2026_hold_collapse_diagnostic_clean25k",
    "pit_split_id": "demo_10_new_long_2010_2026_hold_collapse_diagnostic_clean25k_pit",
    "universe_id": "demo_10_new",
