# ============================================================
# StockInvestmentDSS — Research environment template
# Notebooks, experiments and W&B
# ============================================================

RESEARCH_ENV=local
LOG_LEVEL=INFO

# Shared local data paths
SYSTEM_RUNTIME_DATA_PATH=../system/runtime-data
DUCKDB_PATH=../system/runtime-data/market_research.duckdb

# Canonical NAS-backed DuckDB path
# Used later when guldNAS is mounted into local/k3s/research workloads
GULDNAS_DUCKDB_PATH=/mnt/nas/stockinvestmentdss/duckdb/market_research.duckdb

# Research outputs
RESEARCH_RESULTS_PATH=./results
RESEARCH_FIGURES_PATH=./results/figures
RESEARCH_TABLES_PATH=./results/tables

# Weights & Biases
# Do not commit a real WANDB_API_KEY
WANDB_ENABLED=false
WANDB_PROJECT=StockInvestmentDSS
WANDB_ENTITY=
WANDB_API_KEY=
WANDB_MODE=offline

# Minimal experiment defaults
EXPERIMENT_SEED=42
DEFAULT_TICKERS=AAPL,MSFT,NVDA